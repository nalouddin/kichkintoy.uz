# ================================================================
# Kichkintoy Connect — local test muhiti
# ================================================================

# Application
APP_NAME=Kichkintoy Connect
APP_ENV=development
DEBUG=True

# Xavfsizlik kalitlari
SECRET_KEY=dev-secret-key-change-in-production-32chars
JWT_SECRET_KEY=dev-jwt-key-change-in-production-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin akkaunt — birinchi ishga tushirishda yaratiladi
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin321

# Ma'lumotlar bazasi (docker-compose ichidagi postgres)
DATABASE_URL=postgresql+asyncpg://kichkintoy:kichkintoy@postgres:5432/kichkintoy_db
DATABASE_URL_SYNC=postgresql://kichkintoy:kichkintoy@postgres:5432/kichkintoy_db

# Redis
REDIS_URL=redis://redis:6379/0

# CORS — production uchun real domeningizni yozing
CORS_ORIGINS=["https://sizningdomen.uz","https://www.sizningdomen.uz"]

# File Storage (MinIO) — ixtiyoriy
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kichkintoy-files
MINIO_SECURE=False
