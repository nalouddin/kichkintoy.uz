# ================================================================
# Kichkintoy Connect — muhit o'zgaruvchilari
# Bu faylni nusxalab ".env" nomini bering va qiymatlarni to'ldiring
# ================================================================

# Application
APP_NAME=Kichkintoy Connect
APP_ENV=production
DEBUG=False

# Xavfsizlik kalitlari (kamida 32 ta tasodifiy belgi bo'lsin)
# Generatsiya qilish: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
JWT_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_RANDOM_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin akkaunt (birinchi ishga tushirishda avtomatik yaratiladi)
ADMIN_EMAIL=admin@sizningdomen.uz
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Ma'lumotlar bazasi
DATABASE_URL=postgresql+asyncpg://kichkintoy:STRONG_DB_PASSWORD@postgres:5432/kichkintoy_db
DATABASE_URL_SYNC=postgresql://kichkintoy:STRONG_DB_PASSWORD@postgres:5432/kichkintoy_db

# Redis
REDIS_URL=redis://redis:6379/0

# CORS (frontend URL manzilini yozing)
CORS_ORIGINS=["https://sizningdomen.uz","https://www.sizningdomen.uz"]

# File Storage (MinIO) — ixtiyoriy
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_MINIO_KEY
MINIO_SECRET_KEY=CHANGE_MINIO_SECRET
MINIO_BUCKET=kichkintoy-files
MINIO_SECURE=True
